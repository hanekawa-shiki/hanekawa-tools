{
  "name": "hanekawa-tools",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=24",
    "pnpm": "10.34.4"
  },
  "scripts": {
    "start": "vite",
    "build:all": "pnpm run build:cf & pnpm run build:gh",
    "build:cf": "tsc -b && vite build --mode cf",
    "build:gh": "tsc -b && vite build --mode gh",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "pnpm exec lint-staged",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/figtree": "5.2.10",
    "@fontsource-variable/inter": "5.2.8",
    "@hugeicons/core-free-icons": "4.2.2",
    "@hugeicons/react": "1.1.9",
    "@tailwindcss/vite": "4.3.2",
    "axios": "1.18.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "dayjs": "1.11.21",
    "lunisolar": "2.6.0",
    "next-themes": "0.4.6",
    "parse-torrent": "11.0.21",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-router": "8.1.0",
    "shadcn": "4.13.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@eslint-react/eslint-plugin": "5.11.3",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/parse-torrent": "5.8.8",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-tailwindcss": "4.0.6",
    "globals": "17.7.0",
    "https-proxy-agent": "9.1.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vite-plugin-node-polyfills": "0.28.0"
  },
  "lint-staged": {
    "*.{js,mjs,jsx,ts,tsx,json}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,mjs,json,css,html,md}": [
      "prettier --write"
    ]
  }
}
