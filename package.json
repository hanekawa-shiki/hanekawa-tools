{
  "name": "hanekawa-tools",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24",
    "pnpm": "10.34.5"
  },
  "scripts": {
    "start": "vite",
    "build:all": "pnpm run build:cf & pnpm run build:gh",
    "build:cf": "tsc -b && vite build --mode cf",
    "build:gh": "tsc -b && vite build --mode gh",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "pnpm exec lint-staged",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@dnd-kit/react": "0.5.0",
    "@fontsource-variable/figtree": "5.3.0",
    "@hugeicons/core-free-icons": "4.2.3",
    "@hugeicons/react": "1.1.9",
    "@tanstack/react-virtual": "3.14.7",
    "axios": "1.18.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.21",
    "fuse.js": "7.5.0",
    "lunisolar": "2.6.0",
    "lxgw-wenkai-webfont": "1.7.0",
    "mime-db": "1.54.0",
    "parse-torrent": "11.0.21",
    "pdf-lib": "1.17.1",
    "react": "19.2.8",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.8",
    "react-router": "8.2.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "workbox-window": "7.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.2.0",
    "@eslint-react/eslint-plugin": "5.17.3",
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "26.1.1",
    "@types/parse-torrent": "5.8.8",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-tailwindcss": "4.2.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.1",
    "prettier": "3.9.6",
    "prettier-plugin-tailwindcss": "0.8.1",
    "shadcn": "4.13.1",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vite-plugin-compression": "0.5.1",
    "vite-plugin-node-polyfills": "0.28.0",
    "vite-plugin-pwa": "1.3.0"
  },
  "lint-staged": {
    "*.{js,mjs,jsx,ts,tsx,json}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,mjs,json,css,html,md}": [
      "prettier --write"
    ]
  }
}
